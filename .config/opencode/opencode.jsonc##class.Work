{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "github-copilot/gpt-5-mini",
  "default_agent": "main",
  "share": "disabled",
  "plugin": [
    "opencode-rules@beta",
    "@tarquinen/opencode-dcp@beta",
    "opencode-handoff",
    "caveman-opencode-plugin@latest",
    "file:///home/joe/projects/opencode-fordllm/src/fordllm.ts",
    "file:///home/joe/projects/opencode-workflow/",
  ],
  "experimental": {
    "batch_tool": true,
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": false,
    },
    "chrome-dev-tools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
    "android": {
      "type": "local",
      "command": ["bunx", "-y", "android-mcp-server"],
      "enabled": false,
    },
    "general": {
      "type": "remote",
      "url": "{env:MCP_SEARXNG_URL}",
      "headers": {
        "Authorization": "Bearer {env:MCP_SEARXNG_API_KEY}",
      },
      "enabled": true,
    },
    "code": {
      "type": "remote",
      "url": "{env:MCP_SEARXNG_CODE_URL}",
      "headers": {
        "Authorization": "Bearer {env:MCP_SEARXNG_API_KEY}",
      },
      "enabled": true,
    },
    "web": {
      "type": "local",
      "command": ["bunx", "-y", "intercept-mcp@latest"],
      "environment": {
        "USE_STEALTH_FETCH": "true",
      },
      "enabled": true,
    },
    "smartsheet": {
      "type": "remote",
      "url": "https://mcp.smartsheet.com",
      "headers": {
        "Authorization": "Bearer {env:SMARTSHEET_API_TOKEN}",
      },
      "enabled": false,
    },
  },
  "lsp": {
    "kotlin": {
      "command": ["kotlin-language-server"],
      "extensions": [".kt", ".kts"],
    },
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
    "makefile": {
      "command": [
        "uvx",
        "--from",
        "autotools-language-server",
        "make-language-server",
      ],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "formatter": {
    "mbake": {
      "command": ["uvx", "mbake", "format", "$FILE"],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "permission": {
    "general_web_url_read": "deny",
    "code_web_url_read": "deny",
    "web_search": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny",
    "read_spec": "deny",
    "write_spec": "deny",
    "edit_spec": "deny",
    "read_plan": "deny",
    "write_plan": "deny",
    "edit_plan": "deny",
    "review_spec": "deny",
    "review_plan": "deny",
    "explore": "deny",
    "research": "deny",
    "programmer": "deny",
    "verify_spec_compliance": "deny",
    "code_review": "deny",
    "investigate": "deny",
  },
  "compaction": {
    "auto": false,
    "prune": false,
  },
  "agent": {
    "general": {
      "variant": "high",
    },
    "explore": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high",
    },
    "programmer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high",
    },
    "code-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
    },
    "document-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
    },
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "thinking_budget": 4000,
          },
          "variants": {
            "high": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 32000,
            },
            "medium": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 16000,
            },
            "low": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 8000,
            },
          },
        },
      },
    },
    "fordllm": {
      "name": "FordLLM",
      "models": {
        "gpt-5.5": {
          "id": "gpt-5.5",
          "name": "GPT-5.5",
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 400000,
            "output": 128000,
          },
        },
        "gpt-5.4": {
          "id": "gpt-5.4",
          "name": "GPT-5.4",
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 400000,
            "output": 128000,

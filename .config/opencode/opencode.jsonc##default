{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "github-copilot/gpt-5.4-mini",
  "default_agent": "main",
  "plugin": [
    "opencode-rules@latest",
    "@frap129/oc-buddy@latest",
    "@tarquinen/opencode-dcp@latest",
    "@ex-machina/opencode-anthropic-auth",
    "@opencode-neuralwatt-provider",
  ],
  "experimental": {
    "primary_tools": ["prune"],
    "batch_tool": true,
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": false,
    },
    "searxng": {
      "type": "remote",
      "url": "{env:SEARXNG_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:MCP_HTTP_AUTH_TOKEN}",
      },
      "enabled": true,
    },
  },
  "lsp": {
    "kotlin": {
      "command": ["kotlin-language-server"],
      "extensions": [".kt", ".kts"],
    },
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
    "makefile": {
      "command": [
        "uvx",
        "--from",
        "autotools-language-server",
        "make-language-server",
      ],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "formatter": {
    "mbake": {
      "command": ["uvx", "mbake", "format", "$FILE"],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "permission": {
    "searxng_web_url_read": "deny",
    "bash": {
      "git filter-branch *": "deny",
      "git branch -d": "ask",
      "git branch -D": "ask",
      "git push *": "ask",
      "sudo *": "ask",
    },
  },
  "compaction": {
    "auto": false,
    "prune": true,
  },
  "agent": {
    "general": {
      "variant": "high",
    },
    "explore": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "high",
      "permission": {
        "lsp": "allow",
      },
    },
    "programmer": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "high",
    },
    "code-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
    },
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5",
          "variants": {
            "high": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 32000,
                },
              },
            },
            "medium": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 16000,
                },
              },
            },
            "low": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 8000,
                },
              },
            },
          },
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5",
          "variants": {
            "high": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 32000,
                },
              },
            },
            "medium": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 16000,
                },
              },
            },
            "low": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 8000,
                },
              },
            },
          },
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5",
          "variants": {
            "high": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 16000,
                },
              },
            },
            "medium": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 8000,
                },
              },
            },
            "low": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 4000,
                },
              },
            },
          },
        },
      },
    },
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "thinking_budget": 4000,
          },
          "variants": {
            "high": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 32000,
            },
            "medium": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 16000,
            },
            "low": {
              "thinking": {
                "type": "enabled",
              },
              "thinking_budget": 8000,
            },
          },
        },
        "claude-opus-4.5": {
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "thinking_budget": 4000,
          },
          "variants": {
            "high": {
              "thinking_budget": 31999,
            },
            "medium": {
              "thinking_budget": 16000,
            },
            "low": {
              "thinking_budget": 8000,
            },
          },
        },
      },
    },
    "neuralwatt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NeuralWatt",
      "options": {
        "baseURL": "https://api.neuralwatt.com/v1"
      },
      "models": {
        "Qwen/Qwen3.5-397B-A17B-FP8": {
          "name": "Qwen 3.5 397B",
          "reasoning": true,
          "limit": { "context": 262144, "output": 32768 }
        },
        "moonshotai/Kimi-K2.5": {
          "name": "Kimi K2.5",
          "attachment": true,
          "reasoning": true,
          "limit": { "context": 262144, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "zai-org/GLM-5.1-FP8": {
          "name": "GLM-5.1",
          "reasoning": true,
          "limit": { "context": 202752, "output": 65536 }
        },
        "zai-org/GLM-5-FP8": {
          "name": "GLM-5",

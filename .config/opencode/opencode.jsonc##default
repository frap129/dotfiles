{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "github-copilot/gpt-5.4-mini",
  "default_agent": "main",
  "plugin": [
    "opencode-rules@latest",
    //"/home/joe/Projects/ai/opencode-rules",
    "@tarquinen/opencode-dcp@3.0.4",
    "opencode-google-antigravity-auth",
  ],
  "experimental": {
    "primary_tools": ["prune"],
    "batch_tool": true,
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": false,
    },
    "code-reasoning": {
      "type": "local",
      "command": ["code-reasoning"],
      "enabled": true,
    },
  },
  "lsp": {
    "kotlin": {
      "command": ["kotlin-language-server"],
      "extensions": [".kt", ".kts"],
    },
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
    "makefile": {
      "command": [
        "uvx",
        "--from",
        "autotools-language-server",
        "make-language-server",
      ],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "formatter": {
    "mbake": {
      "command": ["uvx", "mbake", "format", "$FILE"],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "permission": {
    "lsp": "deny",
    "bash": {
      "git filter-branch *": "deny",
      "git branch -d": "ask",
      "git branch -D": "ask",
      "git push *": "ask",
      "sudo *": "ask",
    },
  },
  "compaction": {
    "auto": false,
    "prune": true,
  },
  "agent": {
    "general": {
      "variant": "high",
    },
    "explore": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "permission": {
        "lsp": "allow",
      },
    },
    "programmer": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "high",
    },
    "code-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
    },
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5",
          "variants": {
            "high": {
              "options": {
                "thinking": {
                  "type": "enabled",
                  "budgetTokens": 32000,
                },
              },
            },
            "medium": {
              "options": {

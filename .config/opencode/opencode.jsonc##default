{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "neuralwatt/openai/gpt-oss-20b",
  "default_agent": "main",
  "plugin": [
    "opencode-rules@latest",
    "@frap129/oc-buddy@latest",
    "@tarquinen/opencode-dcp@latest",
    "@ex-machina/opencode-anthropic-auth",
  ],
  "experimental": {
    "primary_tools": ["prune"],
    "batch_tool": true,
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": false,
    },
    "general": {
      "type": "remote",
      "url": "{env:MCP_SEARXNG_URL}",
      "headers": {
        "Authorization": "Bearer {env:MCP_SEARXNG_API_KEY}",
      },
      "enabled": true,
    },
    "code": {
      "type": "remote",
      "url": "{env:MCP_SEARXNG_CODE_URL}",
      "headers": {
        "Authorization": "Bearer {env:MCP_SEARXNG_API_KEY}",
      },
      "enabled": true,
    },
    "web": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "intercept-mcp@latest",
      ],
      "environment": {
        "USE_STEALTH_FETCH": "true"
      },
      "enabled": true,
    },
  },
  "lsp": {
    "kotlin": {
      "command": ["kotlin-language-server"],
      "extensions": [".kt", ".kts"],
    },
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
    "makefile": {
      "command": [
        "uvx",
        "--from",
        "autotools-language-server",
        "make-language-server",
      ],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "formatter": {
    "mbake": {
      "command": ["uvx", "mbake", "format", "$FILE"],
      "extensions": ["Makefile", ".mk"],
    },
  },
  "permission": {
    "general_web_url_read": "deny",
    "code_web_url_read": "deny",
    "web_search": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny",
    "bash": {
      "git filter-branch *": "deny",
      "git branch -d": "ask",
      "git branch -D": "ask",
      "git push *": "ask",
      "sudo *": "ask",
    },
  },
  "compaction": {
    "auto": false,
    "prune": true,
  },
  "agent": {
    "general": {
      "variant": "high",
    },
    "explore": {
      "model": "neuralwatt/Qwen/Qwen3.6-35B-A3B",
    },
    "programmer": {
      "model": "opencode-go/minimax-m2.7",
    },
    "code-reviewer": {
      "model": "opencode-go/qwen3.6-plus",
    },
    "document-reviewer": {
      "model": "opencode-go/qwen3.6-plus",
    },
  },
  "provider": {
    "neuralwatt": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.neuralwatt.com/v1"
      },
      "models": {
        "glm-5-fast": {

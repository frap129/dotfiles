{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "carbonfox",
  "keybinds": {
    "agent_cycle": "ctrl+tab",
    "agent_cycle_reverse": "ctrl+shift+tab"
  },
  "scroll_speed": 10,
  "scroll_acceleration": {
    "enabled": true
  },
  "plugin": [
    "opencode-rules@latest",
    "@tarquinen/opencode-dcp@beta"
  ]
}

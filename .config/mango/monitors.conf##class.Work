# Monitor Rules
# Format: monitorrule=name:output,mfact:float,nmaster:int,layout:name,transform:int,scale:float,x:int,y:int,width:int,height:int,refresh:int

monitorrule=model:0x1777,scale:1,x:3072,y:1080,width:1920,height:1080,refresh:60
monitorrule=model:DELL P3225QE,scale:1.25,x:0,y:0,width:3840,height:2160,refresh:60

# DP-2 (main) to the right of eDP-1, at origin y=0
monitorrule=model:AG276QZD2,scale:1,x:4992,y:900,width:2560,height:1440,refresh:240
